quit-after-last-window-closed = true
shell-integration = zsh
shell-integration-features = cursor,sudo,title,no-ssh-env,no-ssh-terminfo,path
title-report = true
quick-terminal-position = top
quick-terminal-animation-duration = 0.5
quick-terminal-keyboard-interactivity = exclusive
clipboard-read = allow
clipboard-paste-protection = false
window-show-tab-bar = never
window-theme = ghostty
window-decoration = none
window-padding-x = 0
window-padding-y = 0
background-opacity = 0.75
background-blur = true
unfocused-split-opacity = 0.85
selection-clear-on-copy = true

font-size = 20
font-family = "JetBrainsMono Nerd Font"
font-feature = ["liga", "calt"]
mouse-hide-while-typing = true  
mouse-shift-capture = true
right-click-action = copy-or-paste
focus-follows-mouse = true
keybind = ctrl+shift+r=reload_config

keybind = ctrl+shift+p=close_surface
keybind = ctrl+shift+q=new_tab

keybind = ctrl+shift+l=goto_split:previous
keybind = ctrl+shift+k=goto_split:next
keybind = ctrl+shift+o=toggle_tab_overview


keybind = ctrl+shift+g=toggle_split_zoom
keybind = ctrl+shift+f=toggle_quick_terminal
keybind = ctrl+shift+z=undo

keybind = ctrl+shift+m=previous_tab
keybind = ctrl+shift+n=next_tab

keybind = ctrl+shift+w=resize_split:up,20
keybind = ctrl+shift+d=resize_split:down,20
keybind = ctrl+shift+s=resize_split:left,20
keybind = ctrl+shift+a=resize_split:right,20

keybind = ctrl+shift+u=new_split:down
keybind = ctrl+shift+j=new_split:left
keybind = ctrl+shift+y=new_split:up
keybind = ctrl+shift+h=new_split:right

theme = Everforest Dark Hard
background = #1e2326
foreground = #d3c6aa
selection-background = #4c3743
selection-foreground = #d3c6aa
cursor-color = #e69875
cursor-text = #4c3743
palette = 0=#7a8478
palette = 1=#e67e80
palette = 2=#a7c080
palette = 3=#dbbc7f
palette = 4=#7fbbb3
palette = 5=#d699b6
palette = 6=#83c092
palette = 7=#f2efdf
palette = 8=#a6b0a0
palette = 9=#f85552
palette = 10=#8da101
palette = 11=#dfa000
palette = 12=#3a94c5
palette = 13=#df69ba
palette = 14=#35a77c
palette = 15=#fffbef
